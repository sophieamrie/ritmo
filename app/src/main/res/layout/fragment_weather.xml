<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/sceneryBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        app:srcCompat="@drawable/bg_coastal"/>

    <!-- Temperature display -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="24dp"
        android:layout_marginTop="72dp">

        <TextView
            android:id="@+id/tvTemperature"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="24°"
            android:textColor="#FFFFFF"
            android:textSize="64sp"
            android:fontFamily="@font/lora_semibold"/>

        <TextView
            android:id="@+id/tvWeatherDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Partly Cloudy · Jakarta"
            android:textColor="#DDFFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/nunito_extrabold"/>

        <Button
            android:id="@+id/btnRefresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Refresh"
            android:visibility="gone"
            android:fontFamily="@font/nunito_extrabold"
            android:backgroundTint="#F2A58E"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <!-- Weather icon -->
    <TextView
        android:id="@+id/tvWeatherIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="80dp"
        android:layout_marginEnd="24dp"
        android:text="⛅"
        android:textSize="56sp"/>

    <!-- Quote card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="350dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#33FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/tvQuote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Small steps every day lead to big changes."
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/lora_semibold"
                android:lineSpacingMultiplier="1.5"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="— Daily Motivation ✨"
                android:textColor="#BBFFFFFF"
                android:textSize="10sp"
                android:fontFamily="@font/nunito_extrabold"
                android:gravity="end"
                android:layout_marginTop="6dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Bottom Sheet -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="300dp"
        app:behavior_hideable="false"
        app:behavior_fitToContents="true">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="80dp">

                <View
                    android:layout_width="36dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="14dp"
                    android:background="#263D3530"/>

                <!-- Weather stats row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp"
                    android:weightSum="3">

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="?attr/colorSurface">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="10dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💧" android:textSize="18sp" android:layout_marginBottom="2dp"/>
                            <TextView android:id="@+id/tvHumidity" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="78%" android:textSize="16sp" android:fontFamily="@font/lora_semibold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HUMIDITY" android:textSize="8sp" android:textColor="#9B8E87" android:fontFamily="@font/nunito_extrabold" android:letterSpacing="0.1"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="?attr/colorSurface">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="10dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💨" android:textSize="18sp" android:layout_marginBottom="2dp"/>
                            <TextView android:id="@+id/tvWind" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12" android:textSize="16sp" android:fontFamily="@font/lora_semibold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WIND KM/H" android:textSize="8sp" android:textColor="#9B8E87" android:fontFamily="@font/nunito_extrabold" android:letterSpacing="0.1"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="?attr/colorSurface">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="10dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌡️" android:textSize="18sp" android:layout_marginBottom="2dp"/>
                            <TextView android:id="@+id/tvUV" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="26°" android:textSize="16sp" android:fontFamily="@font/lora_semibold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FEELS LIKE" android:textSize="8sp" android:textColor="#9B8E87" android:fontFamily="@font/nunito_extrabold" android:letterSpacing="0.1"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <!-- Forecast -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5-DAY FORECAST"
                    android:textColor="#9B8E87"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="@font/nunito_extrabold"
                    android:layout_marginBottom="10dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvForecast"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </FrameLayout>

    <!-- Floating Bottom Nav Pill -->
    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="?attr/colorSurface">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <LinearLayout
                android:id="@+id/navTasks"
                android:layout_width="72dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_task"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tasks"
                    android:textColor="#9B8E87"
                    android:textSize="9sp"
                    android:fontFamily="@font/nunito_extrabold"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navHabits"
                android:layout_width="72dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_habit"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Habits"
                    android:textColor="#9B8E87"
                    android:textSize="9sp"
                    android:fontFamily="@font/nunito_extrabold"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navWeather"
                android:layout_width="72dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_weather"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Weather"
                    android:textColor="#F2A58E"
                    android:textSize="9sp"
                    android:fontFamily="@font/nunito_extrabold"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>