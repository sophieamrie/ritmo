<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/sceneryBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        app:srcCompat="@drawable/bg_dusk"/>

    <!-- Streak badge -->
    <TextView
        android:id="@+id/tvStreak"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="52dp"
        android:layout_marginEnd="18dp"
        android:text="🔥 7 day streak"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:fontFamily="@font/nunito_extrabold"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:background="@drawable/bg_streak_pill"/>

    <!-- Greeting -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="24dp"
        android:layout_marginTop="72dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DUSK CHECK-IN"
            android:textColor="#CCFFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:fontFamily="@font/nunito_extrabold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Habits"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:lineSpacingMultiplier="1.2"
            android:fontFamily="@font/lora_semibold"/>

    </LinearLayout>

    <!-- Bottom Sheet -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="380dp"
        app:behavior_hideable="false"
        app:behavior_fitToContents="true">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="80dp">

                <View
                    android:layout_width="36dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="14dp"
                    android:background="#263D3530"/>

                <!-- Add habit + THIS WEEK row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="THIS WEEK"
                        android:textColor="#9B8E87"
                        android:textSize="10sp"
                        android:letterSpacing="0.12"
                        android:fontFamily="@font/nunito_extrabold"/>

                    <TextView
                        android:id="@+id/fabAddHabit"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="+"
                        android:textSize="24sp"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_fab_habit"/>

                </LinearLayout>

                <!-- Week dots -->
                <LinearLayout
                    android:id="@+id/weekDotsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp"
                    android:weightSum="7">

                    <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/dot_filled" android:backgroundTint="#A8C5A0"/>
                    <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/dot_filled" android:backgroundTint="#A8C5A0"/>
                    <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/dot_filled" android:backgroundTint="#A8C5A0"/>
                    <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/dot_filled" android:backgroundTint="#A8C5A0"/>
                    <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/dot_filled" android:backgroundTint="#A8C5A0"/>
                    <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/dot_filled" android:backgroundTint="#A8C5A0"/>
                    <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/dot_filled" android:backgroundTint="#E0EDD9"/>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TODAY'S HABITS"
                    android:textColor="#9B8E87"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="@font/nunito_extrabold"
                    android:layout_marginBottom="10dp"/>

                <!-- Empty state -->
                <LinearLayout
                    android:id="@+id/emptyStateHabit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌿"
                        android:textSize="48sp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No habits yet!"
                        android:textSize="16sp"
                        android:fontFamily="@font/lora_semibold"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Start building good habits today"
                        android:textSize="12sp"
                        android:textColor="#9B8E87"
                        android:fontFamily="@font/nunito_extrabold"/>

                </LinearLayout>

                <!-- Habit list -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvHabits"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:paddingBottom="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </FrameLayout>

    <!-- Floating Bottom Nav Pill -->
    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="?attr/colorSurface">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <LinearLayout
                android:id="@+id/navTasks"
                android:layout_width="72dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_task"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tasks"
                    android:textColor="#9B8E87"
                    android:textSize="9sp"
                    android:fontFamily="@font/nunito_extrabold"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navHabits"
                android:layout_width="72dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_habit"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Habits"
                    android:textColor="#F2A58E"
                    android:textSize="9sp"
                    android:fontFamily="@font/nunito_extrabold"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navWeather"
                android:layout_width="72dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_weather"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Weather"
                    android:textColor="#9B8E87"
                    android:textSize="9sp"
                    android:fontFamily="@font/nunito_extrabold"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>