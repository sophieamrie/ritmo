<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Full bleed scenery background -->
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/sceneryBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        app:srcCompat="@drawable/bg_sunrise"/>

    <!-- Greeting text -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="24dp"
        android:layout_marginTop="72dp">

        <ImageButton
            android:id="@+id/btnToggleTheme"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="60dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_streak_pill"
            android:src="@android:drawable/ic_menu_preferences"
            android:tint="#FFFFFF"
            android:padding="8dp"/>

        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GOOD MORNING"
            android:textColor="#CCFFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:fontFamily="@font/nunito_extrabold"/>

        <TextView
            android:id="@+id/tvGreetingTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Let&#8217;s get things done"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:lineSpacingMultiplier="1.2"
            android:fontFamily="@font/lora_semibold"/>

    </LinearLayout>

    <!-- Floating bottom panel -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="340dp"
        android:layout_gravity="bottom"
        app:cardCornerRadius="28dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="#E8FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="0dp">

            <!-- Handle -->
            <View
                android:layout_width="36dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="14dp"
                android:background="#26000000"
                android:backgroundTint="#263D3530"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TODAY"
                android:textColor="#9B8E87"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:fontFamily="@font/nunito_extrabold"
                android:layout_marginBottom="10dp"/>

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/emptyStateTask"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌸"
                    android:textSize="48sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No tasks yet!"
                    android:textSize="16sp"
                    android:textColor="#3D3530"
                    android:fontFamily="@font/lora_semibold"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap + to add your first task"
                    android:textSize="12sp"
                    android:textColor="#9B8E87"
                    android:fontFamily="@font/nunito_extrabold"/>

            </LinearLayout>

            <!-- Task list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTasks"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="8dp"/>

            <!-- Bottom nav -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <LinearLayout
                    android:id="@+id/navTasks"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_task"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tasks"
                        android:textColor="#F2A58E"
                        android:textSize="9sp"
                        android:fontFamily="@font/nunito_extrabold"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navHabits"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_habit"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Habits"
                        android:textColor="#9B8E87"
                        android:textSize="9sp"
                        android:fontFamily="@font/nunito_extrabold"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navWeather"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_weather"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Weather"
                        android:textColor="#9B8E87"
                        android:textSize="9sp"
                        android:fontFamily="@font/nunito_extrabold"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddTask"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="356dp"
        app:backgroundTint="#F2A58E"
        app:tint="@android:color/white"
        android:src="@android:drawable/ic_input_add"
        app:elevation="8dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>